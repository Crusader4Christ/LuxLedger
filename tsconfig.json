{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@services/*": ["apps/luxledger-api/src/services/*"],
      "@api/*": ["apps/luxledger-api/src/api/*"],
      "@lux/ledger": ["packages/ledger/src/index.ts"],
      "@lux/ledger/*": ["packages/ledger/src/*"],
      "@lux/ledger-drizzle-adapter": ["packages/ledger-drizzle-adapter/src/index.ts"],
      "@lux/ledger-drizzle-adapter/*": ["packages/ledger-drizzle-adapter/src/*"]
    },
    "types": ["bun-types"]
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
