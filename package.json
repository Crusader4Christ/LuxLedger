{
  "name": "luxledger",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --watch apps/luxledger-api/src/index.ts",
    "start": "bun run apps/luxledger-api/src/index.ts",
    "test": "bun run test:ci",
    "test:unit": "bun test $(find apps packages -type f -name '*.test.ts' ! -path '*/test/integration/*' | sort)",
    "test:integration": "bun run db:check:test && bun run db:reset:test && bun run db:migrate:test && bun test --max-concurrency=1 $(find apps packages -type f -path '*/test/integration/*.test.ts' | sort)",
    "test:ci": "bun run test:unit && bun run test:integration",
    "test:ledger-http": "bun test packages/ledger-http/src/*.test.ts",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint": "bunx @biomejs/biome check apps/ packages/",
    "lint:fix": "bunx @biomejs/biome check --write apps/ packages/",
    "typecheck": "tsc --noEmit",
    "db:generate": "bash ./scripts/db-generate-named.sh",
    "db:generate:raw": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:check:test": "DATABASE_URL=${DATABASE_URL_TEST:-postgresql://luxledger:luxledger@127.0.0.1:5433/luxledger_test} bun run ./scripts/check-postgres.ts",
    "db:reset:test": "DATABASE_URL=${DATABASE_URL_TEST:-postgresql://luxledger:luxledger@127.0.0.1:5433/luxledger_test} bun run ./scripts/reset-test-database.ts",
    "db:migrate:test": "DATABASE_URL=${DATABASE_URL_TEST:-postgresql://luxledger:luxledger@127.0.0.1:5433/luxledger_test} bunx drizzle-kit migrate",
    "bootstrap:admin-key": "bun run apps/luxledger-api/src/bootstrap-admin-key.ts",
    "contract:verify": "bun test apps/luxledger-api/test/integration/openapi-contract-governance.integration.test.ts"
  },
  "dependencies": {
    "fastify": "^5.7.4",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^22.12.0",
    "bun-types": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "@types/express": "^5.0.6"
  }
}
